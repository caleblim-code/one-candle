// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  trades       Trade[]
  playbooks    Playbook[]
  dailyJournals DailyJournal[]
}

model Playbook {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  entryCriteria String?
  exitCriteria  String?
  riskRules     String?
  chartNotes    String?
  tags          String?
  createdAt     DateTime @default(now())
  trades        Trade[]
}

model Trade {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker       String
  assetClass   String
  direction    String
  entryPrice   Float
  exitPrice    Float?
  positionSize Float
  entryDate    DateTime
  exitDate     DateTime?
  stopLoss     Float?
  takeProfit   Float?
  fees         Float    @default(0)
  pnl          Float?
  status       String   @default("Open") // "Open" or "Closed"
  setupTag     String?
  playbookId   String?
  playbook     Playbook? @relation(fields: [playbookId], references: [id])
  mistakeTags  String?  // comma separated string
  notes        String?
  createdAt    DateTime @default(now())
}

model DailyJournal {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        String   // Format: YYYY-MM-DD
  content     String?
  mentalState String?  // comma separated tags e.g., "Calm, Tilted"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
}
