// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash    String
  timezone        String     @default("UTC")
  currency        String     @default("USD")
  defaultAsset    String     @default("Stocks")
  startingBalance Float      @default(0)
  setupTags       String?    // Stored as JSON string array
  mistakeTags     String?    // Stored as JSON string array
  createdAt       DateTime   @default(now())
  accounts        TradingAccount[]
  trades          Trade[]
  playbooks       Playbook[]
  dailyJournals DailyJournal[]
}

model Playbook {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  entryCriteria String?
  exitCriteria  String?
  riskRules     String?
  chartNotes    String?
  tags          String?
  createdAt     DateTime @default(now())
  trades        Trade[]
}

model TradingAccount {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      String   @default("Live Personal") // Live Personal, Demo/Paper, Prop Firm Challenge, Prop Firm Funded
  balance   Float    @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trades    Trade[]
  rules     PropFirmRules?
  payouts   Payout[]
}

model Trade {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker       String
  assetClass   String
  direction    String
  entryPrice   Float
  exitPrice    Float?
  positionSize Float
  entryDate    DateTime
  exitDate     DateTime?
  stopLoss     Float?
  takeProfit   Float?
  fees         Float    @default(0)
  pnl          Float?
  status       String   @default("Open") // "Open" or "Closed"
  setupTag     String?
  playbookId   String?
  playbook     Playbook? @relation(fields: [playbookId], references: [id])
  accountId    String?
  account      TradingAccount? @relation(fields: [accountId], references: [id])
  mistakeTags  String?  // comma separated string
  notes        String?
  createdAt    DateTime @default(now())
}

model DailyJournal {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        String   // Format: YYYY-MM-DD
  content     String?
  mentalState String?  // comma separated tags e.g., "Calm, Tilted"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
}

model PropFirmRules {
  id               String   @id @default(uuid())
  accountId        String   @unique
  account          TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  firmName         String   @default("Custom")
  maxDailyLoss     Float    @default(0)
  maxTotalDrawdown Float    @default(0)
  profitTarget     Float    @default(0)
  trailingDrawdown Boolean  @default(false)
  minTradingDays   Int      @default(0)
  maxTradingDays   Int?     // optional
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Payout {
  id              String   @id @default(uuid())
  accountId       String
  account         TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amount          Float
  date            DateTime
  status          String   @default("Pending") // Pending, Paid, Rejected
  method          String?  // optional: Wire, ACH, Crypto, PayPal, etc.
  processingDays  Int?     // optional: how many days it took
  reference       String?  // optional: transaction/reference number
  notes           String?  // optional: any notes
  createdAt       DateTime @default(now())
}
